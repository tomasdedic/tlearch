{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"jsx": "react-jsx"
	},
	"include": ["exercises/**/*.ts", "exercises/**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
